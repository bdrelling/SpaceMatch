; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SpaceMatch"
config/version="1.0.0"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/icon.svg"
config/build=1

[autoload]

FocusGuard="*uid://dvgbv1q5c3313"
ManagedInput="*res://addons/components/autoloads/input/managed_input.gd"
FeatureFlagger="*uid://e7nrecb5l6mx"
Settings="*uid://dgn8msqx6nyay"
JoypadLayout="*res://addons/components/autoloads/input/joypad_layout.gd"
SceneLoader="*uid://b1w3ce6q6lcos"
PauseMonitor="*uid://0lyw7qh8m2oe"
ScreenshotCapture="*uid://bm5r8pmyrk1vs"
DeviceOrientation="*res://addons/utilities/device/device_orientation.gd"
Catalogs="*res://autoloads/catalogs.gd"
GameSession="*res://systems/game_session/game_session.gd"
DebugConfig="*res://scenes/debug_screen/debug_config.gd"

[debug]

gdscript/warnings/untyped_declaration=2
gdscript/warnings/unsafe_property_access=2
gdscript/warnings/unsafe_method_access=2
gdscript/warnings/unsafe_cast=2
gdscript/warnings/unsafe_call_argument=2
shapes/collision/shape_color=Color(0, 0.5950001, 0.7, 0.8235294)

[display]

window/size/viewport_width=1117
window/size/viewport_height=1600
window/size/initial_screen=1
window/stretch/mode="canvas_items"
window/handheld/orientation="portrait"
window/size/min_width=558
window/size/min_height=800

[editor_plugins]

enabled=PackedStringArray("res://addons/command_line/plugin.cfg", "res://addons/components/plugin.cfg", "res://addons/effect_system/plugin.cfg", "res://addons/gdUnit4/plugin.cfg", "res://addons/grid_system/plugin.cfg", "res://addons/logging/plugin.cfg", "res://addons/utilities/plugin.cfg")

[gui]

theme/default_theme_scale=2.0
theme/custom="uid://uy3znkll7jlqy"

[input]

ui_accept={
