[gd_resource type="Resource" script_class="Ability" format=3]

[ext_resource type="Script" path="res://systems/effect/core/models/ability.gd" id="1_ability"]
[ext_resource type="Script" path="res://systems/effect/core/models/effect.gd" id="2_effect"]
[ext_resource type="Script" path="res://systems/effect/core/models/resource_cost.gd" id="3_cost"]
[ext_resource type="Script" path="res://systems/effect/core/data/targets/self_target.gd" id="4_target"]
[ext_resource type="Script" path="res://systems/effect/core/data/actions/modify_stat_action.gd" id="5_modify"]
[ext_resource type="Script" path="res://systems/effect/core/data/actions/apply_status_action.gd" id="6_apply"]
[ext_resource type="Script" path="res://systems/effect/core/data/amounts/constant_amount.gd" id="7_amount"]
[ext_resource type="Resource" path="res://data/stats/block.tres" id="8_block"]
[ext_resource type="Resource" path="res://data/ability_resources/shields.tres" id="9_shields"]

[sub_resource type="Resource" id="Amount"]
script = ExtResource("7_amount")
value = 3

[sub_resource type="Resource" id="Target"]
script = ExtResource("4_target")

[sub_resource type="Resource" id="GrantBlock"]
script = ExtResource("5_modify")
stat = ExtResource("8_block")
amount = SubResource("Amount")
tag = &"shield"
subtracts = false

[sub_resource type="Resource" id="ApplyShield"]
script = ExtResource("6_apply")
status = &"shield"
count = 1

[sub_resource type="Resource" id="EffectBlock"]
script = ExtResource("2_effect")
target = SubResource("Target")
action = SubResource("GrantBlock")

[sub_resource type="Resource" id="EffectStatus"]
script = ExtResource("2_effect")
target = SubResource("Target")
action = SubResource("ApplyShield")

[sub_resource type="Resource" id="Cost"]
script = ExtResource("3_cost")
resource = ExtResource("9_shields")
amount = 2

[resource]
script = ExtResource("1_ability")
name = &"raise_shields"
costs = Array[ExtResource("3_cost")]([SubResource("Cost")])
effects = Array[ExtResource("2_effect")]([SubResource("EffectBlock"), SubResource("EffectStatus")])
