# Shared
GAME_NAME=SpaceMatch
GAME_NAME_SLUG=space-match
BUILD_DIRECTORY=.builds
GODOT_PROJECT_DIR=source

# itch.io
ITCH_GAME_IDENTIFIER=aerodynamo/${GAME_NAME_SLUG}
ITCH_BUILD_DIRECTORY=${BUILD_DIRECTORY}

# iOS
IOS_BUILD_DIRECTORY=${BUILD_DIRECTORY}/iOS
IOS_PROJECT_PATH=${IOS_BUILD_DIRECTORY}/${GAME_NAME}.xcodeproj
IOS_SCHEME_NAME=${GAME_NAME}
IOS_APP_NAME=${GAME_NAME}
IOS_BUNDLE_IDENTIFIER=com.briandrelling.${GAME_NAME}
IOS_SIMULATOR_NAME="iPhone 17 Pro"
IOS_IPHONE_DEVICE_NAME="briPhone"
IOS_IPAD_DEVICE_NAME="briPad"
IOS_TEAM_ID=79E585EFP3
IOS_IPA_PATH=${IOS_BUILD_DIRECTORY}/${GAME_NAME}.ipa

# macOS
MACOS_BUILD_DIRECTORY=${BUILD_DIRECTORY}/macOS/Debug
MACOS_DISK_IMAGE_PATH=${MACOS_BUILD_DIRECTORY}/${GAME_NAME}.dmg
MACOS_APP_PATH=${MACOS_DISK_IMAGE_PATH}/${GAME_NAME}.app