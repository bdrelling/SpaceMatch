{
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "~/",
        "./.env.local",
        "**/.env.local",
        "./.mcp.json"
      ],
      "allowRead": [
        ".",
        "~/.claude",
        "${OBSIDIAN_VAULT}",
        "docs/obsidian"
      ],
      "denyWrite": [
        "."
      ],
      "allowWrite": [
        "./.claude",
        "./docs",
        "./scripts",
        "./source",
        "./Makefile",
        "./README.md"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Skill(take-screenshot)",
      "Skill(take-screenshot:*)",
      "Skill(obsidian)",
      "Skill(obsidian:*)",
      "Skill(excalidraw)",
      "Skill(excalidraw:*)",
      "WebSearch",
      "WebFetch",
      "Read(**)",
      "Read(~/.claude/**)",
      "Write(.claude/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(source/**)",
      "Write(Makefile)",
      "Write(README.md)",
      "Bash(bash scripts/*)",
      "Bash(./scripts/*)",
      "Bash(chmod +x *)",
      "Bash(make help *)",
      "Bash(make play:*)",
      "Bash(make playtest:*)",
      "Bash(make test:*)",
      "Bash(make test-debug:*)",
      "Bash(make clean)",
      "Bash(make check)",
      "Bash(make import)",
      "Bash(godot:*)"
    ],
    "deny": [],
    "ask": [],
    "additionalDirectories": [
      "${OBSIDIAN_VAULT}",
      "docs/obsidian"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gdd-guard.sh"
          }
        ]
      }
    ]
  }
}
